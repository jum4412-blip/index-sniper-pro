#!/usr/bin/env bash
set -Eeuo pipefail

MARKER='__LARRY_VWAP_SHADOW_PAYLOAD_BELOW__'
TMP_DIR="$(mktemp -d -t larry-vwap-shadow.XXXXXX)"
cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT INT TERM

MARKER_LINE="$(awk -v marker="$MARKER" '$0 == marker { print NR; exit }' "$0")"
if [[ -z "$MARKER_LINE" ]]; then
  echo "❌ 내장 패키지 마커를 찾지 못했습니다." >&2
  exit 1
fi

tail -n +$((MARKER_LINE + 1)) "$0" | base64 --decode > "$TMP_DIR/payload.tar.gz"
tar -xzf "$TMP_DIR/payload.tar.gz" -C "$TMP_DIR"

[[ -x "$TMP_DIR/payload/install_vwap_shadow.sh" ]] || {
  echo "❌ 설치 스크립트 추출 실패" >&2
  exit 1
}

(
  cd "$TMP_DIR/payload"
  sha256sum -c MANIFEST.sha256
)

exec bash "$TMP_DIR/payload/install_vwap_shadow.sh" "$@"
exit $?

