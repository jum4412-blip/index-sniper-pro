[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=$ROOT
Environment=PYTHONPATH=$ROOT
ExecStart=$PY $ROOT/scripts/larry_noentry_alert.py
TimeoutStartSec=240
SERVICE

