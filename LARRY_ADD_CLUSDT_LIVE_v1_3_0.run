#!/usr/bin/env bash
set -Eeuo pipefail

MARKER='__LARRY_CLUSDT_PAYLOAD_BELOW__'
TMP_DIR="$(mktemp -d -t larry-clusdt-v1.3.0.XXXXXX)"
cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT INT TERM

MARKER_LINE="$(awk -v marker="$MARKER" '$0 == marker { print NR; exit }' "$0")"
if [[ -z "$MARKER_LINE" ]]; then
  echo "❌ 내장 패키지 마커를 찾지 못했습니다." >&2
  exit 1
fi

PAYLOAD_START=$((MARKER_LINE + 1))
tail -n +"$PAYLOAD_START" "$0" \
  | base64 --decode \
  > "$TMP_DIR/payload.tar.gz"

tar -xzf "$TMP_DIR/payload.tar.gz" -C "$TMP_DIR"
[[ -x "$TMP_DIR/payload/install_cl_live.sh" ]] || {
  echo "❌ 내장 설치 스크립트를 추출하지 못했습니다." >&2
  exit 1
}

bash "$TMP_DIR/payload/install_cl_live.sh" "$@"
exit $?

